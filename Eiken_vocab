    .word-item-meaning { font-size: 12px; color: var(--slate); margin-top: 2px; }
    .word-item-mnemonic { font-size: 11px; color: #a5b4fc; margin-top: 2px; }
    .word-item-right { text-align: right; flex-shrink: 0; margin-left: 10px; }
