    .answer-box.official-ans { background: rgba(45,212,191,0.05); border: 1px solid rgba(45,212,191,0.2); }
    .ans-label { font-size: 11px; color: var(--slate); margin-bottom: 2px; }
    .ans-value { font-weight: 600; }
    .ans-value.teal { color: var(--teal); font-weight: 700; }
    .session-stats { display: flex; justify-content: center; gap: 24px; margin-bottom: 20px; }
    .session-stat-val { font-size: 28px; font-weight: 800; }
    .session-stat-label { font-size: 11px; color: var(--slate); }
    .mode-row { display: flex; gap: 8px; margin-bottom: 14px; align-items: center; }
    .due-count { margin-left: auto; font-size: 12px; color: var(--slate); }
    .section-title { font-size: 13px; color: var(--slate); margin-bottom: 12px; }
    .center { text-align: center; }
    .emoji-big { font-size: 42px; margin-bottom: 10px; }
    .card-title { font-size: 18px; font-weight: 700; margin-bottom: 6px; }
    .card-subtitle { font-size: 13px; color: var(--slate); margin-bottom: 18px; }
    .flex-row { display: flex; gap: 8px; }
    .flex-1 { flex: 1; }
