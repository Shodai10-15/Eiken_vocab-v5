      margin-bottom: 8px;
      border-radius: 12px;
      cursor: pointer;
      text-align: left;
      font-size: 14px;
      font-family: inherit;
      transition: all .15s;
      background: rgba(30,41,59,0.5);
      border: 1px solid var(--border);
      color: #e2e8f0;
