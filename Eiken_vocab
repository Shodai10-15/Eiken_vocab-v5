  {word:"vulnerable",meaning:"傷つきやすい・脆弱な",mnemonic:"vulner(傷)+able→傷つきやすい",etymology:"ラテン語 vulnus「傷」"},
  {word:"wane",meaning:"（月が）欠ける・衰退する",mnemonic:"wane(欠ける)→月が欠けるように衰える",etymology:"古英語 wanian「減る」"},
  {word:"zenith",meaning:"頂点・絶頂",mnemonic:"zeni(上)+th→最上点",etymology:"アラビア語 samt「方向」"},
  {word:"zeal",meaning:"熱意・熱心さ",mnemonic:"zeal(熱心)→熱心さそのもの",etymology:"ギリシャ語 zelos「熱心」"},
  {word:"abase",meaning:"（地位・品位を）落とす・卑しめる",mnemonic:"a+base(底)→底に落とす",etymology:"古フランス語 abaissier「下げる」"},
  {word:"abdicate",meaning:"（王位・責任を）放棄する",mnemonic:"ab(離れて)+dicate(宣言)→宣言して離れる",etymology:"ラテン語 abdicare「放棄を宣言する」"},
  {word:"aberration",meaning:"逸脱・異常",mnemonic:"ab(離れて)+erration(さまよい)→正道から逸れる",etymology:"ラテン語 aberrare「道に迷う」"},
  {word:"abjection",meaning:"卑屈さ・悲惨な状態",mnemonic:"ab(下に)+ject(投げる)+ion→底に投げ捨てた状態",etymology:"ラテン語 abicere「投げ捨てる」"},
  {word:"abnegate",meaning:"（権利・義務を）否定する・断念する",mnemonic:"ab+negate(否定)→完全に否定する",etymology:"ラテン語 abnegare「否定する」"},
  {word:"abominate",meaning:"ひどく嫌う・嫌悪する",mnemonic:"ab+omin(前兆)+ate→不吉な前兆として嫌う",etymology:"ラテン語 abominari「不吉と見なす」"}
];

// ── Storage ────────────────────────────────────────────────────
const KEY = 'eiken1_html_v1';
function loadCards() { try { const r = localStorage.getItem(KEY); return r ? JSON.parse(r) : null; } catch { return null; } }
function saveCards(c) { try { localStorage.setItem(KEY, JSON.stringify(c)); } catch {} }
function makeCard(w, id) {
  return {id, word: w.word, meaning: w.meaning, mnemonic: w.mnemonic||'', etymology: w.etymology||'',
    interval: 1, repetitions: 0, easeFactor: 2.5, nextReview: 0, totalReviews: 0, correctCount: 0};
}
function buildInitial() { return WORDS.map((w, i) => makeCard(w, i + 1)); }
function mergeNew(cards, newWords) {
  const ex = new Set(cards.map(c => c.word.toLowerCase()));
  let maxId = Math.max(...cards.map(c => c.id), 0);
  const added = [];
  newWords.forEach(w => {
    if (w.word && w.meaning && !ex.has(w.word.toLowerCase())) {
      maxId++;
      added.push(makeCard(w, maxId));
      ex.add(w.word.toLowerCase());
    }
  });
  return [...cards, ...added];
}

// ── Helpers ────────────────────────────────────────────────────
function getDue(cards) { return cards.filter(c => c.nextReview <= Date.now()); }
function shuffle(a) {
  const b = [...a];
  for (let i = b.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i+1)); [b[i],b[j]]=[b[j],b[i]]; }
  return b;
}
function getChoices(cards, correct) { return shuffle([correct, ...shuffle(cards.filter(c => c.id !== correct.id)).slice(0,3)]); }
function mastery(card) {
  if (!card.totalReviews) return {label:'未学習', color:'#475569'};
  const r = card.correctCount / card.totalReviews;
  if (r >= 0.9 && card.repetitions >= 3) return {label:'マスター', color:'#2dd4bf'};
  if (r >= 0.7) return {label:'学習中', color:'#f59e0b'};
  return {label:'要復習', color:'#f87171'};
}

// ── App State ──────────────────────────────────────────────────
let cards = loadCards() || buildInitial();
let tab = 'study';
let mode = 'choice';
let queue = [], qIdx = 0, phase = 'question';
let choices = [], selected = null;
let writeInput = '', writeResult = null;
let sessionCorrect = 0, sessionWrong = 0;
let sessionDone = false, showHint = false;
let currentCard = null;
let dashFilter = 'all', dashSearch = '';
let csvText = '', importMsg = '', importMsgType = '';

function persist() { saveCards(cards); }

// ── Render ─────────────────────────────────────────────────────
function render() {
  document.getElementById('app').innerHTML = buildApp();
  attachEvents();
}

function buildApp() {
  const due = getDue(cards);
  return `
    <header>
      <div class="logo">EIKEN 1級 Vocab</div>
      <div class="header-info">${cards.length}語収録</div>
    </header>
    <div class="tabs">
      <button class="tab-btn ${tab==='study'?'active':''}" onclick="switchTab('study')">学習</button>
      <button class="tab-btn ${tab==='dashboard'?'active':''}" onclick="switchTab('dashboard')">ダッシュボード</button>
      <button class="tab-btn ${tab==='import'?'active':''}" onclick="switchTab('import')">インポート</button>
    </div>
    <div class="container">
      ${tab==='study' ? buildStudy(due) : ''}
      ${tab==='dashboard' ? buildDashboard() : ''}
      ${tab==='import' ? buildImport() : ''}
    </div>`;
}

function buildStudy(due) {
  let html = `<div class="mode-row">
    <button class="btn ${mode==='choice'?'':'btn-ghost'}" style="padding:7px 16px;font-size:13px" onclick="switchMode('choice')">選択式</button>
    <button class="btn ${mode==='write'?'':'btn-ghost'}" style="padding:7px 16px;font-size:13px" onclick="switchMode('write')">記述式</button>
    <span class="due-count">復習: <b style="color:var(--teal)">${due.length}</b>件</span>
  </div>`;

  if (!queue.length && !sessionDone) {
    html += `<div class="card center">
      <div class="emoji-big">${due.length ? '📚' : '🎊'}</div>
      <div class="card-title">${due.length ? due.length+'件の単語が待っています' : '今日の復習は完了！'}</div>
      <div class="card-subtitle">SM-2アルゴリズムで最適タイミングで出題</div>
      ${due.length
        ? `<button class="btn" onclick="startSession()">スタート 🚀</button>`
        : `<button class="btn btn-ghost" onclick="resetAll()">全単語をリセットして練習</button>`}
    </div>`;
    return html;
  }

  if (sessionDone) {
    const total = sessionCorrect + sessionWrong;
    const pct = total ? Math.round(sessionCorrect / total * 100) : 0;
    html += `<div class="card center">
      <div class="emoji-big">🎉</div>
      <div class="card-title" style="font-size:20px;margin-bottom:14px">セッション完了！</div>
      <div class="session-stats">
        <div><div class="session-stat-val" style="color:var(--teal)">${sessionCorrect}</div><div class="session-stat-label">正解</div></div>
        <div><div class="session-stat-val" style="color:var(--red)">${sessionWrong}</div><div class="session-stat-label">不正解</div></div>
        <div><div class="session-stat-val" style="color:var(--purple)">${pct}%</div><div class="session-stat-label">正答率</div></div>
      </div>
      <button class="btn" onclick="backToTop()">戻る</button>
    </div>`;
    return html;
  }

  if (!currentCard) return html;
  const pct = (qIdx / queue.length) * 100;
  html += `<div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>`;
  html += `<div class="counter-text">${qIdx+1} / ${queue.length}</div>`;
  html += `<div class="card">`;
  html += `<div class="word-display">${currentCard.word}</div>`;

  if (phase === 'question') {
    html += `<div class="center" style="margin-bottom:14px">
      <button class="btn btn-ghost" style="padding:5px 14px;font-size:12px" onclick="toggleHint()">
        ${showHint ? 'ヒントを隠す' : '💡 ヒントを見る'}
      </button>
    </div>`;
    if (showHint && (currentCard.mnemonic || currentCard.etymology)) {
      html += `<div class="hint-box">
        ${currentCard.mnemonic ? `<div class="hint-mnemonic">💡 ${currentCard.mnemonic}</div>` : ''}
        ${currentCard.etymology ? `<div class="hint-etymology">📖 ${currentCard.etymology}</div>` : ''}
      </div>`;
    }
  }

  if (phase === 'result' && (currentCard.mnemonic || currentCard.etymology)) {
    html += `<div class="hint-box">
      ${currentCard.mnemonic ? `<div class="hint-mnemonic">💡 ${currentCard.mnemonic}</div>` : ''}
      ${currentCard.etymology ? `<div class="hint-etymology">📖 ${currentCard.etymology}</div>` : ''}
    </div>`;
  }

  if (mode === 'choice') {
    if (phase === 'question') html += `<div class="center" style="font-size:13px;color:var(--slate);margin-bottom:12px">この単語の意味は？</div>`;
    choices.forEach(c => {
      let cls = 'choice-btn';
      if (phase === 'result') {
        if (c.id === currentCard.id) cls += ' correct';
        else if (c.id === selected) cls += ' wrong';
        else cls += ' other-result';
      }
      const check = (phase === 'result' && c.id === currentCard.id) ? ' ✓' : '';
      html += `<button class="${cls}" ${phase==='result'?'disabled':''} onclick="handleChoice(${c.id})">${c.meaning}${check}</button>`;
    });
  } else {
    if (phase === 'question') {
      html += `<div class="center" style="font-size:13px;color:var(--slate);margin-bottom:10px">日本語で意味を入力してください</div>
        <input id="write-input" class="input-field" type="text" value="${writeInput.replace(/"/g,'&quot;')}" placeholder="日本語で意味を入力…" oninput="writeInput=this.value" onkeydown="if(event.key==='Enter'&&this.value.trim())checkWrite()">
        <button class="btn btn-full" onclick="checkWrite()" ${!writeInput.trim()?'disabled':''}>答え合わせ</button>`;
    } else {
      html += `<div class="answer-box ${writeResult?'correct-ans':'wrong-ans'}">
        <div class="ans-label">あなたの回答</div>
        <div class="ans-value">${writeInput}</div>
      </div>
      <div class="answer-box official-ans">
        <div class="ans-label">正解</div>
        <div class="ans-value teal">${currentCard.meaning}</div>
      </div>
      <div class="center" style="font-size:11px;color:var(--slate);margin-bottom:8px">採点を修正できます</div>
      <div class="flex-row">
        <button class="btn btn-success flex-1" onclick="overrideWrite(true)">✅ 正解にする</button>
        <button class="btn btn-danger flex-1" onclick="overrideWrite(false)">❌ 不正解にする</button>
      </div>`;
    }
  }
  html += `</div>`;

  if (phase === 'result') {
    html += `<button class="btn btn-full" onclick="nextCard()">${qIdx+1 < queue.length ? '次へ →' : '結果を見る 🎉'}</button>`;
  }
  return html;
}

function buildDashboard() {
  const masteredCount = cards.filter(c => mastery(c).label === 'マスター').length;
  const studiedCount = cards.filter(c => c.totalReviews > 0).length;
  const reviewCount = cards.filter(c => mastery(c).label === '要復習').length;
  let html = `<div class="stats-grid">
    <div class="stat-card"><div class="stat-value" style="color:var(--purple)">${cards.length}</div><div class="stat-label">総単語</div></div>
    <div class="stat-card"><div class="stat-value" style="color:var(--teal)">${studiedCount}</div><div class="stat-label">学習済み</div></div>
    <div class="stat-card"><div class="stat-value" style="color:var(--amber)">${masteredCount}</div><div class="stat-label">マスター</div></div>
    <div class="stat-card"><div class="stat-value" style="color:var(--red)">${reviewCount}</div><div class="stat-label">要復習</div></div>
  </div>
  <div class="filter-row">
    ${['all','未学習','学習中','マスター','要復習'].map(f =>
      `<button class="btn ${dashFilter===f?'':'btn-ghost'}" style="padding:5px 12px;font-size:12px" onclick="setFilter('${f}')">${f==='all'?'すべて':f}</button>`
    ).join('')}
  </div>
  <input class="input-field" type="text" value="${dashSearch.replace(/"/g,'&quot;')}" placeholder="単語・意味で検索…" oninput="dashSearch=this.value;render()" style="margin-bottom:12px">
  <div class="card">`;

  const filtered = cards.filter(c => {
    if (dashFilter !== 'all' && mastery(c).label !== dashFilter) return false;
    if (dashSearch && !c.word.toLowerCase().includes(dashSearch.toLowerCase()) && !c.meaning.includes(dashSearch)) return false;
    return true;
  });
  html += `<div class="section-title">${filtered.length}件</div><div class="word-list">`;
  filtered.slice(0, 300).forEach(c => {
    const m = mastery(c);
    const rate = c.totalReviews ? Math.round(c.correctCount / c.totalReviews * 100) : 0;
    html += `<div class="word-item">
      <div class="word-item-left">
        <div class="word-item-name">${c.word}</div>
        <div class="word-item-meaning">${c.meaning}</div>
        ${c.mnemonic ? `<div class="word-item-mnemonic">💡 ${c.mnemonic}</div>` : ''}
      </div>
      <div class="word-item-right">
        <span class="tag" style="background:${m.color}22;color:${m.color};border:1px solid ${m.color}44">${m.label}</span>
        <div class="word-item-count">${c.totalReviews}回/${rate}%</div>
      </div>
    </div>`;
  });
  html += `</div></div>`;
  return html;
}

function buildImport() {
  return `<div class="card">
    <div style="font-size:15px;font-weight:700;margin-bottom:8px">CSVで単語をインポート</div>
    <div style="font-size:13px;color:var(--slate);margin-bottom:12px;line-height:1.8">
      形式: <code style="color:var(--teal);font-size:12px">単語, 意味, 覚え方, 語源</code>
    </div>
    <textarea class="input-field" placeholder="ubiquitous,どこにでもある,ubi=どこでも,ラテン語 ubique" oninput="csvText=this.value">${csvText}</textarea>
    <button class="btn btn-full" style="margin-bottom:10px" onclick="handleImport()" ${!csvText.trim()?'disabled':''}>インポート実行</button>
    ${importMsg ? `<div class="import-msg ${importMsgType==='ok'?'ok':'err'}">${importMsg}</div>` : ''}
    <hr>
    <button class="btn btn-danger btn-full" onclick="handleReset()">データをリセット</button>
  </div>`;
}

// ── Event Handlers ─────────────────────────────────────────────
function attachEvents() {
  // input focus for write mode
  const wi = document.getElementById('write-input');
  if (wi) { wi.focus(); wi.value = writeInput; }
}

function switchTab(t) { tab = t; render(); }
function switchMode(m) { mode = m; queue = []; sessionDone = false; render(); }
function toggleHint() { showHint = !showHint; render(); }
function setFilter(f) { dashFilter = f; render(); }

function startSession() {
  const due = getDue(cards);
  if (!due.length) return;
  queue = shuffle(due);
  qIdx = 0; phase = 'question';
  selected = null; writeInput = ''; writeResult = null;
  sessionCorrect = 0; sessionWrong = 0;
  sessionDone = false; showHint = false;
  currentCard = queue[0];
  if (mode === 'choice') choices = getChoices(cards, currentCard);
  render();
}

function backToTop() { queue = []; sessionDone = false; render(); }
function resetAll() { cards = cards.map(c => ({...c, nextReview: 0})); persist(); render(); }

function applyAnswer(card, ok) {
  const quality = ok ? 4 : 1;
  const upd = sm2(card, quality);
  cards = cards.map(c => c.id !== card.id ? c : {
    ...c, ...upd,
    totalReviews: c.totalReviews + 1,
    correctCount: c.correctCount + (ok ? 1 : 0)
  });
  if (ok) sessionCorrect++; else sessionWrong++;
  persist();
}

function nextCard() {
  if (qIdx + 1 >= queue.length) { sessionDone = true; currentCard = null; render(); return; }
  qIdx++;
  currentCard = queue[qIdx];
  phase = 'question'; selected = null;
  writeInput = ''; writeResult = null; showHint = false;
  if (mode === 'choice') choices = getChoices(cards, currentCard);
  render();
}

function handleChoice(id) {
  if (phase !== 'question') return;
  selected = id;
  phase = 'result';
  applyAnswer(currentCard, id === currentCard.id);
  render();
}

function checkWrite() {
  const input = writeInput.trim();
  const ok = currentCard.meaning.includes(input) || input === currentCard.meaning;
  writeResult = ok;
  phase = 'result';
  applyAnswer(currentCard, ok);
  render();
}

function overrideWrite(ok) {
  const wasOk = writeResult;
  cards = cards.map(c => {
    if (c.id !== currentCard.id) return c;
    const u = {totalReviews: c.totalReviews - 1, correctCount: c.correctCount - (wasOk ? 1 : 0)};
    const upd = sm2({...c, ...u}, ok ? 4 : 1);
    return {...c, ...u, ...upd, totalReviews: u.totalReviews + 1, correctCount: u.correctCount + (ok ? 1 : 0)};
  });
  if (wasOk && !ok) { sessionCorrect--; sessionWrong++; }
  if (!wasOk && ok) { sessionWrong--; sessionCorrect++; }
  writeResult = ok;
  persist();
  render();
}

function handleImport() {
  try {
    const lines = csvText.trim().split('\n').filter(Boolean);
    const ws = lines.map(l => {
      const p = l.split(',');
      return {word: p[0]?.trim(), meaning: p[1]?.trim(), mnemonic: p[2]?.trim()||'', etymology: p[3]?.trim()||''};
    }).filter(w => w.word && w.meaning);
    cards = mergeNew(cards, ws);
    persist();
    importMsg = `✅ ${ws.length}件インポート完了`;
    importMsgType = 'ok';
    csvText = '';
  } catch {
    importMsg = '❌ フォーマットエラー';
    importMsgType = 'err';
  }
  render();
}

function handleReset() {
  if (!confirm('全データをリセットしますか？')) return;
  cards = buildInitial();
  persist();
  importMsg = '✅ リセット完了';
  importMsgType = 'ok';
  render();
}

// ── Init ───────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  render();
});
</script>
<div id="app"></div>
</body>
</html>
