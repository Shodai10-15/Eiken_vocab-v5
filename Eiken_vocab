      background: rgba(15,23,42,0.6);
      border-bottom: 1px solid var(--border);
      padding: 0 14px;
      overflow-x: auto;
    }
    .tab-btn {
      padding: 11px 18px;
      border: none;
      cursor: pointer;
      background: none;
      font-family: inherit;
      font-size: 13px;
      font-weight: 700;
      color: var(--slate);
      border-bottom: 3px solid transparent;
      transition: all .15s;
      white-space: nowrap;
    }
    .tab-btn.active { color: var(--teal); border-bottom-color: var(--teal); }
    .container { max-width: 620px; margin: 0 auto; padding: 18px 14px; }
    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 22px 18px;
      margin-bottom: 14px;
      backdrop-filter: blur(6px);
